{
  "name": "healthline",
  "version": "0.1.0",
  "private": true,
  "description": "FHIR Patient Timeline Viewer with AI-generated plain-language summaries.",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:client": "npm run test --workspace client",
    "test:server": "npm run test --workspace server"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
